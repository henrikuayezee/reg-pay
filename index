    </div>
  </section>

  <div class="layout">

    <div class="chat-panel">
      <div class="chat-top">
        <div class="brand">
          <div class="brand-icon"><i class="fa-solid fa-brain"></i></div>
          <div>
            <h3>AI Registration Assistant</h3>
            <p>Interactive onboarding experience</p>
          </div>
        </div>
        <div class="live-pill">LIVE REGISTRATION</div>
      </div>
      <div class="progress">
        <div class="progress-fill" id="progressFill"></div>
      </div>
