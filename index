            <div class="ref">REF: <span id="successRef"></span></div>
          </div>
        </div>
      </div>

      <!-- PAY LATER -->
      <div class="paylater-wrap" id="payLaterWrap">
        <div class="paylater-card">
          <h2>We'll Be Waiting 🚀</h2>
          <p>AI Future Summit 2026 is shaping up to be an unforgettable experience. Whenever you're ready, come back and complete your registration to secure your seat.</p>
          <button class="return-btn" onclick="showPayment()">Return To Payment</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
var WEBHOOK_URL = 'https://script.google.com/macros/s/AKfycbxbvtlfyvZnhjIH5JL6nbRV9ECRCbdKjojM5kw73U6dxKFpSf2bEefejSM8fZ73ahOZ/exec';

/* ── BACKGROUND ── */
var cv=document.getElementById('bg'), cx=cv.getContext('2d'), W, H, nodes=[];
function resize(){ W=cv.width=innerWidth; H=cv.height=innerHeight; }
function initNodes(){
  nodes=[];
  for(var i=0;i<120;i++) nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,r:Math.random()*2+1});
}
function animate(){
  cx.clearRect(0,0,W,H);
  for(var i=0;i<nodes.length;i++){
    for(var j=i+1;j<nodes.length;j++){
      var dx=nodes[i].x-nodes[j].x, dy=nodes[i].y-nodes[j].y, d=Math.sqrt(dx*dx+dy*dy);
      if(d<130){ cx.beginPath(); cx.strokeStyle='rgba(255,107,0,'+(1-d/130)*.1+')'; cx.moveTo(nodes[i].x,nodes[i].y); cx.lineTo(nodes[j].x,nodes[j].y); cx.stroke(); }
    }
  }
  for(var k=0;k<nodes.length;k++){
    var n=nodes[k];
    cx.beginPath(); cx.arc(n.x,n.y,n.r,0,Math.PI*2); cx.fillStyle='rgba(255,140,50,.18)'; cx.fill();
    n.x+=n.vx; n.y+=n.vy;
    if(n.x<0||n.x>W)n.vx*=-1; if(n.y<0||n.y>H)n.vy*=-1;
  }
  requestAnimationFrame(animate);
}
resize(); initNodes(); animate();
window.addEventListener('resize',function(){ resize(); initNodes(); });

/* ── STORAGE ── */
var STORAGE_KEY='ai_future_summit_2026';
function saveProgress(paymentState){
  localStorage.setItem(STORAGE_KEY, JSON.stringify({ step:step, answers:answers, leadId:leadId, paymentState:paymentState||null }));
}
function loadProgress(){
  var saved=localStorage.getItem(STORAGE_KEY);
  if(!saved) return null;
  try{ return JSON.parse(saved); }catch(e){ return null; }
}
function clearProgress(){ localStorage.removeItem(STORAGE_KEY); }

/* ── LEAD ID ── */
function generateLeadId(){
  return 'lead_' + Date.now() + '_' + Math.random().toString(36).substr(2,6);
}

/* ── QUESTIONS ──
   Countable steps: name, email, phone, role, interest, goal = 6
*/
var questions=[
  {
    id:'welcome',
    bot:"Hey there 👋<br><br><strong>AI Future Summit 2026</strong> is bringing together innovators, creators, developers, founders, and AI enthusiasts for an unforgettable experience.<br><br>Ready to secure your place?",
    type:'choice', skip:true,
    choices:["Absolutely 🔥","Tell me more"]
  },
  {
    id:'tell_more',
    bot:"Great question! The AI Future Summit 2026 features:<br><br>🎤 <strong>Keynote speakers</strong> from top AI companies<br>🛠 <strong>Hands-on workshops</strong> you can apply immediately<br>🤝 <strong>Networking sessions</strong> with 300+ attendees<br>🚀 <strong>Live AI demos</strong> that will blow your mind<br><br>Still interested?",
    type:'choice', skip:true, branchOnly:true,
    choices:["Count me in 🔥","Let's register"]
  },
  {
    id:'name',
    bot:"Amazing 🚀<br><br>Before we continue, what is your full name?",
    type:'text', validation:'name'
  },
  {
    id:'email',
    bot:"Great, <strong>{name}</strong>! What email address should we use to send your confirmation and event updates?",
    type:'text', validation:'email'
  },
  {
    id:'phone',
    bot:"Perfect. And your phone number?",
    type:'text', validation:'phone'
  },
  {
    id:'role',
    bot:"Which of these best describes your world right now?",
    type:'choice',
    choices:["Student","Developer","Founder / Entrepreneur","Creative","Corporate Professional","AI Curious"]
  },
  {
    id:'interest',
    bot:"What excites you MOST about AI right now?",
    type:'choice',
    choices:["Making money with AI","Automation","Building products","Content creation","Career growth","Networking"]
  },
  {
    id:'goal',
    bot:"If you leave the summit with ONE major win, what should it be?",
    type:'choice',
    choices:["Practical AI skills","Industry connections","Business ideas","Career direction","Confidence using AI"]
  },
  {
    id:'payment',
    bot:"You sound exactly like the kind of person this event was designed for.<br><br>Are you ready to secure your seat now?",
    type:'choice',
    choices:["Yes, let's do it 🔥","I'll pay later"]
  }
];

var COUNTABLE = questions.filter(function(q){ return !q.skip && !q.branchOnly && q.id !== 'payment'; });
var TOTAL_STEPS = COUNTABLE.length; // 6
var step=0, answers={}, answeredCount=0;
var leadId = generateLeadId();
var feed=document.getElementById('chatFeed');
var progressFill=document.getElementById('progressFill');

/* ── PROGRESS ── */
function updateProgress(){
  answeredCount++;
  progressFill.style.width=Math.min(Math.round((answeredCount/TOTAL_STEPS)*100),100)+'%';
}

/* ── HELPERS ── */
function scrollBottom(){ setTimeout(function(){ window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'}); },50); }
function interpolate(str){
  if(answers.name) str=str.replace(/\{name\}/g, answers.name.split(' ')[0]);
  return str;
}

/* ── BOT MESSAGE ── */
function botMessage(html){
  return new Promise(function(resolve){
    var typing=document.createElement('div');
    typing.className='bot-row';
    typing.innerHTML='<div class="bot-avatar"><i class="fa-solid fa-brain"></i></div><div class="bot-bubble"><div class="typing"><span></span><span></span><span></span></div></div>';
    feed.appendChild(typing); scrollBottom();
    setTimeout(function(){
      typing.remove();
      var row=document.createElement('div');
      row.className='bot-row';
      row.innerHTML='<div class="bot-avatar"><i class="fa-solid fa-brain"></i></div><div class="bot-bubble">'+html+'</div>';
      feed.appendChild(row); scrollBottom(); resolve();
    },900);
  });
}

/* ── USER MESSAGE ── */
function userMessage(text){
  return new Promise(function(resolve){
    var row=document.createElement('div');
    row.className='user-row';
    row.innerHTML='<div class="user-bubble">'+text+'</div>';
    feed.appendChild(row); scrollBottom();
    setTimeout(resolve,300);
  });
}

/* ── SHOW QUESTION ── */
function showQuestion(){
  if(step>=questions.length) return;
  var q=questions[step];
  if(q.branchOnly){ step++; showQuestion(); return; }

  botMessage(interpolate(q.bot)).then(function(){

    if(q.type==='choice'){
      var wrap=document.createElement('div');
      wrap.className='choices';
      q.choices.forEach(function(choice){
        var btn=document.createElement('button');
        btn.className='choice-btn';
        btn.innerText=choice;
        btn.addEventListener('click', function(){
          wrap.querySelectorAll('.choice-btn').forEach(function(b){ b.disabled=true; b.style.opacity='0.5'; });
          btn.disabled=false; btn.style.opacity='1'; btn.classList.add('selected');
          answers[q.id]=choice;
          userMessage(choice).then(function(){
            wrap.remove();

            if(q.id==='welcome'){
              if(choice==='Tell me more'){
                step=questions.findIndex(function(x){ return x.id==='tell_more'; });
                questions[step].branchOnly=false; showQuestion();
              } else {
                step=questions.findIndex(function(x){ return x.id==='name'; }); showQuestion();
              }
              return;
            }

            if(q.id==='tell_more'){
              questions[step].branchOnly=true;
              step=questions.findIndex(function(x){ return x.id==='name'; }); showQuestion();
              return;
            }

            if(q.id==='payment'){
              progressFill.style.width='100%';
              if(choice.toLowerCase().includes('later')){
                sendPayLater();
                saveProgress('later');
                document.getElementById('payLaterWrap').style.display='block';
                scrollBottom();
              } else {
                showPayment();
              }
              return;
            }

            updateProgress(); saveProgress(); step++; showQuestion();
          });
        });
        wrap.appendChild(btn);
      });
      feed.appendChild(wrap); scrollBottom();
    }

    if(q.type==='text'){
      var wrap=document.createElement('div');
      wrap.className='text-input-wrap';
      var inputType = q.validation === 'email' ? 'email' : 'text';
      wrap.innerHTML='<input type="'+inputType+'" class="text-input" id="textInput" placeholder="Type your answer and press Enter..." /><button class="send-btn" id="sendBtn"><i class="fa-solid fa-paper-plane"></i></button>';
      var errDiv=document.createElement('div');
      errDiv.className='input-error'; errDiv.id='inputError';
      feed.appendChild(wrap); feed.appendChild(errDiv); scrollBottom();

      var inp=document.getElementById('textInput');
      var sBtn=document.getElementById('sendBtn');
      inp.focus();

      function submitText(){
        var val=inp.value.trim();
        var errEl=document.getElementById('inputError');
        if(!val){ errEl.textContent='Please enter a value.'; errEl.style.display='block'; return; }

        if(q.validation==='name'){
          var parts=val.split(/\s+/);
          if(parts.length<2||parts[1]===''){
            errEl.textContent='Please enter your first and last name.';
            errEl.style.display='block'; return;
          }
        }

        if(q.validation==='email'){
          var emailRegex=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if(!emailRegex.test(val)){
            errEl.textContent='Please enter a valid email address.';
            errEl.style.display='block'; return;
          }
        }

        if(q.validation==='phone'){
          var clean=val.replace(/[\s\-\+]/g,'');
          if(!/^[0-9]+$/.test(clean)){ errEl.textContent='Please enter a valid number (digits only).'; errEl.style.display='block'; return; }
          if(clean.length<10){ errEl.textContent='Please enter a valid 10-digit number.'; errEl.style.display='block'; return; }
        }

        errEl.style.display='none';
        wrap.remove(); errDiv.remove();
        answers[q.id]=val;
        updateProgress(); saveProgress();
        userMessage(val).then(function(){ step++; showQuestion(); });
      }

      inp.addEventListener('keydown',function(e){ if(e.key==='Enter') submitText(); });
      sBtn.addEventListener('click', submitText);
    }
  });
}

/* ── SHOW PAYMENT ── */
function showPayment(){
  document.getElementById('payLaterWrap').style.display='none';
  document.getElementById('paymentWrap').style.display='block';
  // Populate read-only summary
  document.getElementById('summaryName').textContent  = answers.name  || '';
  document.getElementById('summaryEmail').textContent = answers.email || '';
  document.getElementById('summaryPhone').textContent = answers.phone || '';
  saveProgress('payment');
  scrollBottom();
}

/* ── SEND PAY LATER ── */
function sendPayLater(){
  fetch(WEBHOOK_URL, {
    method:'POST', mode:'no-cors',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      event:    'pay.later',
      lead_id:  leadId,
      name:     answers.name     || '',
      phone:    answers.phone    || '',
      email:    answers.email    || '',
      role:     answers.role     || '',
      interest: answers.interest || '',
      goal:     answers.goal     || ''
    })
  }).catch(function(err){ console.warn('Pay later log failed:', err); });
}

/* ── SEND CHAT ANSWERS AFTER PAYMENT ── */
function sendChatAnswers(reference){
  fetch(WEBHOOK_URL, {
    method:'POST', mode:'no-cors',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      event:     'chat.answers',
      reference: reference,
      email:     answers.email    || '',
      role:      answers.role     || '',
      interest:  answers.interest || '',
      goal:      answers.goal     || ''
    })
  }).catch(function(err){ console.warn('Chat answers sync failed:', err); });
}

/* ── PAYSTACK ── */
var PK='pk_test_dadcc832b1c7b24797e1a24897edb2bf8fcbe127';

function showPayError(msg){ var el=document.getElementById('payError'); el.textContent=msg; el.style.display='block'; }
function clearPayError(){ document.getElementById('payError').style.display='none'; }
function setPayLoading(on){
  document.getElementById('paySpinner').style.display=on?'block':'none';
  document.getElementById('payBtnIcon').style.display=on?'none':'inline';
  document.getElementById('payBtnText').textContent=on?'Processing...':'Pay GHS 500.00';
  document.getElementById('payBtn').disabled=on;
}

function launchPaystack(){
  clearPayError();
  var name  = answers.name  || '';
  var email = answers.email || '';
  var phone = answers.phone || '';

  if(!name || !email || !phone){
    showPayError('Some details are missing. Please go back and complete the form.');
    return;
  }

  setPayLoading(true);

  var handler=PaystackPop.setup({
    key:PK,
    email:email,
    amount:50000,
    currency:'GHS',
    metadata:{
      custom_fields:[
        {display_name:'Full Name', variable_name:'full_name', value:name},
        {display_name:'Phone',     variable_name:'phone',     value:phone},
        {display_name:'Lead ID',   variable_name:'lead_id',   value:leadId},
        {display_name:'Role',      variable_name:'role',      value:answers.role||''},
        {display_name:'Interest',  variable_name:'interest',  value:answers.interest||''},
        {display_name:'Goal',      variable_name:'goal',      value:answers.goal||''}
      ]
    },
    callback:function(response){
      setPayLoading(false);
      sendChatAnswers(response.reference);
      clearProgress();
      document.getElementById('paymentForm').style.display='none';
      document.getElementById('successBox').style.display='block';
      document.getElementById('successRef').innerText=response.reference;
      scrollBottom();
    },
    onClose:function(){ setPayLoading(false); }
  });

  handler.openIframe();
}

/* ── RESTORE SESSION ── */
function restoreSession(){
  var saved=loadProgress();
  if(!saved){ setTimeout(function(){ showQuestion(); },1000); return; }
  step=saved.step||0;
  answers=saved.answers||{};
  if(saved.leadId) leadId=saved.leadId;

  var restoredKeys=Object.keys(answers).filter(function(k){
    var q=questions.find(function(x){ return x.id===k; });
    return q && !q.skip && !q.branchOnly && q.id!=='payment';
  });
  answeredCount=restoredKeys.length;
  progressFill.style.width=Math.min(Math.round((answeredCount/TOTAL_STEPS)*100),100)+'%';

  if(Object.keys(answers).length>0){
    var row=document.createElement('div');
    row.className='bot-row';
    row.innerHTML='<div class="bot-avatar"><i class="fa-solid fa-brain"></i></div><div class="bot-bubble">Welcome back <strong>'+(answers.name||'')+'</strong> 👋<br><br>Your registration progress has been restored.</div>';
    feed.appendChild(row);
  }

  if(saved.paymentState==='later'){ document.getElementById('payLaterWrap').style.display='block'; return; }
  if(saved.paymentState==='payment'){ showPayment(); return; }
  showQuestion();
}

restoreSession();
