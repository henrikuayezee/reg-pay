<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AI Future Summit 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<script src="https://js.paystack.co/v1/inline.js"></script>
<style>
:root{
  --primary:#ff6b00;
  --primary2:#ff9d4d;
  --bg:#fff8f2;
  --text:#111827;
  --muted:#6b7280;
}
*{ margin:0; padding:0; box-sizing:border-box; }
body{ font-family:'Inter',sans-serif; background:var(--bg); overflow-x:hidden; color:var(--text); position:relative; }
canvas#bg{ position:fixed; inset:0; z-index:0; pointer-events:none; }
.container{ position:relative; z-index:2; width:100%; max-width:1200px; margin:auto; padding:24px; }

/* HERO */
.hero{ position:relative; min-height:720px; border-radius:40px; overflow:hidden; margin-bottom:36px; box-shadow:0 30px 80px rgba(0,0,0,0.16); }
.hero img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
.hero-overlay{ position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,.9),rgba(0,0,0,.45),rgba(0,0,0,.2)); }
.hero-content{ position:relative; z-index:2; height:100%; padding:70px; display:flex; flex-direction:column; justify-content:flex-end; color:white; }
.hero-pill{ align-self:flex-start; padding:10px 18px; border-radius:100px; background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.18); backdrop-filter:blur(12px); font-size:12px; font-weight:700; letter-spacing:.08em; margin-bottom:24px; }
.hero h1{ font-family:'Outfit',sans-serif; font-size:78px; line-height:.95; font-weight:800; margin-bottom:24px; max-width:760px; }
.hero-sub{ max-width:760px; line-height:1.8; color:rgba(255,255,255,.88); font-size:20px; margin-bottom:30px; }
.event-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
.event-card{ background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.18); backdrop-filter:blur(16px); border-radius:24px; padding:20px; transition:.25s; }
.event-card:hover{ transform:translateY(-5px); }
.event-card i{ font-size:20px; color:#ffb074; margin-bottom:14px; }
.event-card span{ display:block; font-size:11px; text-transform:uppercase; opacity:.7; margin-bottom:6px; }
.event-card strong{ line-height:1.6; font-size:15px; }

/* LAYOUT */
.layout{ display:grid; grid-template-columns:1fr 400px; gap:28px; }

/* CHAT */
.chat-panel{ background:rgba(255,255,255,.68); backdrop-filter:blur(18px); border-radius:34px; padding:30px; box-shadow:0 20px 60px rgba(0,0,0,.08); }
.chat-top{ display:flex; justify-content:space-between; align-items:center; margin-bottom:26px; }
.brand{ display:flex; gap:12px; align-items:center; }
.brand-icon{ width:42px; height:42px; border-radius:14px; background:linear-gradient(135deg,var(--primary),var(--primary2)); display:flex; align-items:center; justify-content:center; color:white; }
.brand h3{ font-family:'Outfit',sans-serif; font-size:20px; }
.brand p{ font-size:13px; color:var(--muted); }
.live-pill{ padding:8px 14px; border-radius:100px; background:#fff0e5; color:var(--primary); font-size:12px; font-weight:700; }
.progress{ width:100%; height:6px; background:#f4dfd0; border-radius:100px; overflow:hidden; margin-bottom:30px; }
.progress-fill{ width:0%; height:100%; background:linear-gradient(90deg,var(--primary),var(--primary2)); transition:.4s; }
.chat-feed{ display:flex; flex-direction:column; gap:20px; }

.bot-row{ display:flex; gap:12px; align-items:flex-start; animation:fadeUp .4s ease forwards; }
.bot-avatar{ width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--primary),var(--primary2)); display:flex; align-items:center; justify-content:center; color:white; flex-shrink:0; }
.bot-bubble{ background:white; padding:18px; border-radius:0 20px 20px 20px; max-width:560px; line-height:1.8; box-shadow:0 10px 30px rgba(0,0,0,.05); }
.bot-bubble strong{ color:var(--primary); }

.user-row{ display:flex; justify-content:flex-end; animation:fadeUp .4s ease forwards; }
.user-bubble{ background:linear-gradient(135deg,var(--primary),var(--primary2)); color:white; padding:14px 18px; border-radius:20px 0 20px 20px; max-width:420px; line-height:1.6; }

.choices{ display:flex; flex-wrap:wrap; gap:10px; margin-top:12px; }
.choice-btn{ border:1.5px solid #f0e8e0; background:white; padding:12px 18px; border-radius:100px; font-weight:600; cursor:pointer; transition:.2s; font-family:'Inter',sans-serif; font-size:14px; }
.choice-btn:hover{ transform:translateY(-2px); background:var(--primary); color:white; border-color:var(--primary); }
.choice-btn.selected{ background:var(--primary); color:white; border-color:var(--primary); }
.choice-btn:disabled{ opacity:0.5; cursor:not-allowed; transform:none; }

.text-input-wrap{ margin-top:18px; display:flex; gap:10px; }
.text-input{ flex:1; border:1.5px solid #f0e8e0; outline:none; padding:14px 16px; border-radius:16px; background:white; font-size:15px; font-family:'Inter',sans-serif; transition:border-color .2s; }
.text-input:focus{ border-color:var(--primary); }
.text-input::placeholder{ color:#bbb; }
.send-btn{ width:46px; height:46px; background:linear-gradient(135deg,var(--primary),var(--primary2)); border:none; border-radius:14px; color:white; font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:.2s; }
.send-btn:hover{ opacity:.88; }
.input-error{ font-size:12px; color:#ef4444; margin-top:6px; display:none; }

/* SIDE */
.side{ position:sticky; top:24px; height:fit-content; background:rgba(255,255,255,.68); backdrop-filter:blur(18px); border-radius:34px; padding:28px; box-shadow:0 20px 60px rgba(0,0,0,.08); }
.side h3{ font-family:'Outfit',sans-serif; font-size:30px; margin-bottom:14px; }
.side > p{ color:var(--muted); line-height:1.8; margin-bottom:24px; }
.feature{ display:flex; gap:14px; margin-bottom:20px; }
.feature-icon{ width:42px; height:42px; border-radius:14px; background:#fff0e5; display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0; }
.feature strong{ display:block; margin-bottom:5px; }
.feature span{ font-size:13px; color:var(--muted); }

/* PAYMENT */
.payment-wrap,.paylater-wrap{ display:none; margin-top:24px; }
.payment-card,.paylater-card{ background:white; border-radius:28px; padding:30px; box-shadow:0 20px 60px rgba(0,0,0,.08); }
.payment-card h2,.paylater-card h2{ font-family:'Outfit',sans-serif; font-size:30px; margin-bottom:10px; }
.payment-card > p,.paylater-card > p{ line-height:1.8; color:var(--muted); margin-bottom:22px; font-size:14px; }
.input-group{ margin-bottom:16px; }
.input-group label{ display:block; margin-bottom:7px; font-weight:600; font-size:13px; }
.input-group input{ width:100%; border:1.5px solid #f0e8e0; background:#f3f4f6; padding:13px 15px; border-radius:14px; outline:none; font-family:'Inter',sans-serif; font-size:14px; color:#888; cursor:not-allowed; }
.pay-error{ font-size:12px; color:#ef4444; background:#fef2f2; border:1px solid #fee2e2; padding:10px; border-radius:10px; margin-bottom:14px; display:none; font-family:'Inter',sans-serif; }
.pay-btn,.return-btn{ width:100%; border:none; background:linear-gradient(135deg,var(--primary),var(--primary2)); color:white; padding:15px; border-radius:16px; font-weight:700; cursor:pointer; transition:.2s; font-size:15px; font-family:'Inter',sans-serif; display:flex; align-items:center; justify-content:center; gap:8px; }
.pay-btn:hover,.return-btn:hover{ transform:translateY(-2px); opacity:.92; }
.pay-btn:disabled{ opacity:.45; cursor:not-allowed; transform:none; }
.pay-spinner{ width:15px; height:15px; border:2px solid rgba(255,255,255,.3); border-top-color:#fff; border-radius:50%; animation:spin .7s linear infinite; display:none; }
.pay-secure{ display:flex; align-items:center; justify-content:center; gap:6px; margin-top:10px; font-size:11px; color:#94a3b8; }

/* SUMMARY BOX */
.summary-box{ background:#fff8f2; border:1px solid rgba(255,107,0,0.15); border-radius:14px; padding:14px 16px; margin-bottom:20px; }
.summary-box p{ font-size:13px; color:var(--muted); margin-bottom:4px; }
.summary-box p span{ color:var(--text); font-weight:600; }

/* SUCCESS */
.success{ display:none; text-align:center; }
.success-icon{ width:72px; height:72px; border-radius:50%; background:#22c55e; color:white; display:flex; align-items:center; justify-content:center; font-size:30px; margin:0 auto 18px; }
.success h2{ font-family:'Outfit',sans-serif; font-size:34px; margin-bottom:10px; }
.success p{ color:var(--muted); line-height:1.8; margin-bottom:16px; font-size:14px; }
.ref{ background:#f3f4f6; padding:14px 16px; border-radius:12px; font-family:monospace; font-size:12px; text-align:left; }
.ref span{ color:var(--primary); }

/* TYPING */
.typing{ display:flex; gap:6px; padding:6px 0; }
.typing span{ width:8px; height:8px; border-radius:50%; background:#ffb074; animation:bounce 1s infinite; }
.typing span:nth-child(2){ animation-delay:.2s; }
.typing span:nth-child(3){ animation-delay:.4s; }
@keyframes bounce{ 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-6px); } }
@keyframes fadeUp{ from{ opacity:0; transform:translateY(12px); } to{ opacity:1; transform:translateY(0); } }
@keyframes spin{ to{ transform:rotate(360deg); } }

/* MOBILE */
@media(max-width:1000px){
  .layout{ grid-template-columns:1fr; }
  .event-grid{ grid-template-columns:repeat(2,1fr); }
  .hero h1{ font-size:56px; }
  .side{ position:static; }
}
@media(max-width:700px){
  .hero{ min-height:850px; }
  .hero-content{ padding:36px; }
  .hero h1{ font-size:42px; }
  .event-grid{ grid-template-columns:1fr; }
}
</style>
</head>

<body>
<canvas id="bg"></canvas>

<div class="container">

  <section class="hero">
    <img src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?q=80&w=1600&auto=format&fit=crop">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-pill">LIMITED SEATS AVAILABLE</div>
      <h1>AI Future Summit 2026</h1>
      <div class="hero-sub">Discover how artificial intelligence is transforming careers, business, creativity, and innovation through immersive workshops, live demos, and networking experiences.</div>
      <div class="event-grid">
        <div class="event-card">
          <i class="fa-solid fa-location-dot"></i>
          <span>Venue</span>
          <strong>Accra International Conference Centre</strong>
        </div>
        <div class="event-card">
          <i class="fa-solid fa-calendar"></i>
          <span>Date</span>
          <strong>Saturday, August 16 2026</strong>
        </div>
        <div class="event-card">
          <i class="fa-solid fa-clock"></i>
          <span>Time</span>
          <strong>9:00 AM — 4:00 PM</strong>
        </div>
        <div class="event-card">
          <i class="fa-solid fa-users"></i>
          <span>Experience</span>
          <strong>Networking, AI Demos & Workshops</strong>
        </div>
